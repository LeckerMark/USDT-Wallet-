# .env.example

# Environment variables needed for Vercel deployment

# WalletConnect ID
REACT_APP_WALLETCONNECT_ID=your_walletconnect_id_here

# Safe Wallet Address
REACT_APP_SAFE_WALLET=your_safe_wallet_address_here

# Other blockchain configuration

# The API URL for the blockchain service
REACT_APP_BLOCKCHAIN_API_URL=https://api.yourblockchainservice.com

# Network type (mainnet, testnet, etc.)
REACT_APP_NETWORK_TYPE=mainnet